# ====================
# AI API 配置 (选择其一)
# ====================

# 方案 1: MiniMax (推荐国内使用)
MINIMAX_API_KEY=你的MiniMax API密钥
MINIMAX_GROUP_ID=你的Group ID (可选)
MINIMAX_MODEL=abab6.5s-chat (可选，默认)

# 方案 2: Anthropic Claude
# ANTHROPIC_API_KEY=你的Claude API密钥

# 方案 3: OpenAI
# OPENAI_API_KEY=你的OpenAI API密钥

# ====================
# Supabase 配置 (可选)
# ====================
# SUPABASE_URL=你的Supabase项目URL
# SUPABASE_KEY=你的Supabase匿名密钥
